# LLM API Configuration (OpenAI-compatible)
# Works with ANY OpenAI-compatible provider: OpenRouter, OpenAI, Ollama, LM Studio

# OpenRouter (recommended for cloud models with free + paid tiers)
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_API_KEY=your_openrouter_api_key_here
LLM_MODEL=google/gemini-2.5-flash-lite

# Ollama (local)
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=gemma3:4b

# LM Studio (local)
# LLM_BASE_URL=http://localhost:1234/v1
# LLM_API_KEY=lm-studio

# Whisper Configuration (local speech-to-text via faster-whisper)
WHISPER_MODEL=base.en
